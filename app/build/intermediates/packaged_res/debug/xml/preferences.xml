<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="General">

        <SwitchPreferenceCompat
            app:key="notifications"
            app:title="Enable Notifications"
            app:summary="Receive push notifications"
            app:defaultValue="true" />

        <ListPreference
            app:key="map_type"
            app:title="Map Type"
            app:summary="Choose the default map type"
            app:entries="@array/map_type_entries"
            app:entryValues="@array/map_type_values"
            app:defaultValue="normal" />

    </PreferenceCategory>

    <PreferenceCategory app:title="Location">

        <SwitchPreferenceCompat
            app:key="location_tracking"
            app:title="Location Tracking"
            app:summary="Allow the app to track your location"
            app:defaultValue="false" />

        <EditTextPreference
            app:key="default_location"
            app:title="Default Location"
            app:summary="Set default location name"
            app:defaultValue="Sydney" />

    </PreferenceCategory>

    <PreferenceCategory app:title="Display">

        <SwitchPreferenceCompat
            app:key="dark_mode"
            app:title="Dark Mode"
            app:summary="Enable dark theme"
            app:defaultValue="false" />

        <ListPreference
            app:key="zoom_level"
            app:title="Default Zoom Level"
            app:summary="Set the default map zoom level"
            app:entries="@array/zoom_level_entries"
            app:entryValues="@array/zoom_level_values"
            app:defaultValue="10" />

    </PreferenceCategory>

</PreferenceScreen>
